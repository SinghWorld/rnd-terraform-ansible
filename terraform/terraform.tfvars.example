# terraform.tfvars
# -----------------
# DO NOT commit this file — it is in .gitignore
# Copy this to terraform.tfvars and fill in your values.
#
# OR use environment variable instead of this file:
#   export TF_VAR_winrm_password="YourStr0ngP@ss!"

aws_region     = "us-east-1"
project_name   = "win-demo"
key_name       = "win-demo-key"
instance_type  = "t3.medium"
winrm_username = "ansible_admin"

# Set your password here (must match what's in userdata.ps1)
# winrm_password = "YourStr0ngP@ss!"
